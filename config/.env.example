# LLM — Google AI Studio API key (for text generation via Gemini/Gemma - free tier)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_API_KEY=your_api_key_here

# TTS — Google Cloud service account key path is configured in config.json
# under google.tts_key_path (relative to config/ directory).
# Place your service account JSON file in the config/ folder.

# API authentication (optional)
# When set, every request must include the header: X-Api-Key: <value>
# Leave empty (or unset) to run in open/dev mode with no authentication.
API_KEY=
